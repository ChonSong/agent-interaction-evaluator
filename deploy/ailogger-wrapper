#!/usr/bin/env python3
"""Wrapper that resolves ailogger paths dynamically, then execs the real server."""

from __future__ import annotations

import os
import sys

# Resolve workspace root relative to this script (supports symlinks / home expansions)
SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
WORKSPACE_ROOT = os.path.normpath(os.path.join(SCRIPT_DIR, "..", "..", ".."))

REPO_DIR = os.path.join(WORKSPACE_ROOT, "agent-interaction-evaluator-repo")
ENV_FILE = os.path.join(REPO_DIR, ".env")

# Load .env vars if present (e.g. API keys the logger might need)
if os.path.exists(ENV_FILE):
    with open(ENV_FILE) as f:
        for line in f:
            line = line.strip()
            if "=" in line and not line.startswith("#"):
                k, v = line.split("=", 1)
                os.environ.setdefault(k.strip(), v.strip())

os.environ.setdefault("AILOGGER_SOCKET", "/tmp/ailogger.sock")
os.environ.setdefault(
    "PYTHONPATH",
    os.path.join(REPO_DIR, "src"),
)

# Re-exec the real logger serve command using the Python in the venv or system python
python_exec = sys.executable  # use the same interpreter running this script
os.execv(python_exec, [python_exec, "-m", "evaluator.logger", "serve"])
